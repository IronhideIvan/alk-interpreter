import { log } from "console";

// "new Box<int, string>(...)" against "class Box<T>" supplies the wrong
// number of type arguments — type arguments must be either fully omitted or
// fully specified with the correct count.

class Box<T> {
    public T value;

    public new(T value) {
        this.value = value;
    }
}

var box = new Box<int, string>(5);

log("unreachable");
