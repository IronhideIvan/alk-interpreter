import { log } from "console";

// Assigning a value of the wrong type to a field declared as the bare type
// parameter "T" is a RuntimeException once "T" has been bound by "new
// Box<int>(...)".

class Box<T> {
    public T value;

    public new(T value) {
        this.value = value;
    }
}

var box = new Box<int>(5);
box.value = "not an int";

log("unreachable");
