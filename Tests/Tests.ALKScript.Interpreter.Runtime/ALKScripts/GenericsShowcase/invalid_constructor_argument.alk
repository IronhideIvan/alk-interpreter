import { log } from "console";

// Passing a value of the wrong type for a constructor parameter declared as
// the bare type parameter "T" is a RuntimeException once "T" has been bound
// by "new Box<int>(...)".

class Box<T> {
    public T value;

    public new(T value) {
        this.value = value;
    }
}

var box = new Box<int>("not an int");

log("unreachable");
