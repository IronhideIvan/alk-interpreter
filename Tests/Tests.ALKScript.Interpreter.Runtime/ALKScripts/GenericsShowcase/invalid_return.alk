import { log } from "console";

// Returning a value of the wrong type from a method declared to return the
// bare type parameter "T" is a RuntimeException once "T" has been bound by
// "new Box<int>(...)".

class Box<T> {
    public T value;

    public new(T value) {
        this.value = value;
    }

    public function T wrongValue() {
        return "not an int";
    }
}

var box = new Box<int>(5);
box.wrongValue();

log("unreachable");
