import { log, delayValue } from "console";

// ── basic lambda: arithmetic, explicit "lambda<...>" type ──────────────────
//
// "lambda<R, P1, P2, ...>" is a function type: R is the return type, P1, P2,
// ... are the parameter types. A lambda expression is written
// "ReturnType (ParamType name, ...) => { ... }".

lambda<int, int, int> add = int (int x, int y) => { return x + y; };
log(`add = ${add(2, 3)}`);

// ── closures capture enclosing locals by reference ──────────────────────────

int factor = 10;
lambda<int, int> scale = int (int x) => { return x * factor; };
log(`scale = ${scale(4)}`);

factor = 100;
log(`scale-after-factor-change = ${scale(4)}`);

// ── lambdas as parameters (higher-order functions) ──────────────────────────

function void forEachInt(int[] items, lambda<void, int> action) {
    foreach (var item in items) {
        action(item);
    }
}

forEachInt([1, 2, 3], void (int n) => { log(`item = ${n}`); });

// ── lambdas capture the enclosing "this" inside instance methods ───────────

class Accumulator {
    private int total = 0;

    public function void addAll(int[] values) {
        forEachInt(values, void (int n) => { this.total += n; });
    }

    public function int getTotal() {
        return this.total;
    }
}

var acc = new Accumulator();
acc.addAll([1, 2, 3, 4]);
log(`total = ${acc.getTotal()}`);

// ── async lambdas ────────────────────────────────────────────────────────

lambda<int, int> doubleAsync = async int (int x) => {
    int value = await delayValue(x);
    return value * 2;
};
int doubled = await doubleAsync(5);
log(`doubled = ${doubled}`);

// ── array.map / array.filter with lambda callbacks ──────────────────────────

var doubledItems = [1, 2, 3].map(int (int n) => { return n * 2; });
log(`doubledItems = [${doubledItems[0]}, ${doubledItems[1]}, ${doubledItems[2]}]`);

var evenItems = [1, 2, 3, 4].filter(bool (int n) => { return n % 2 == 0; });
log(`evenItems = [${evenItems[0]}, ${evenItems[1]}]`);

// "map"/"filter" callbacks may themselves be "async" — each call is awaited
// internally, so the result is a plain array, no extra "await" needed.
var asyncDoubled = [1, 2, 3].map(async int (int n) => {
    int value = await delayValue(n);
    return value * 2;
});
log(`asyncDoubled = [${asyncDoubled[0]}, ${asyncDoubled[1]}, ${asyncDoubled[2]}]`);

log("done");
