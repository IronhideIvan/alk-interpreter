// A small animal hierarchy used by the end-to-end test.
//
// Hierarchy:
//   Animal (abstract)
//     Dog
//       GuideDog          <- overrides speak() and chains base.speak()
//     Cat

export abstract class Animal {
    protected string name;

    public new(string name) {
        this.name = name;
    }

    public abstract function string speak();

    public function string getName() {
        return this.name;
    }
}

export class Dog extends Animal {
    public new(string name) {
        base(name);
    }

    public override function string speak() {
        return this.name + " barks: Woof!";
    }
}

export class Cat extends Animal {
    public new(string name) {
        base(name);
    }

    public override function string speak() {
        return this.name + " meows: Meow!";
    }
}

// Three-level chain: GuideDog extends Dog extends Animal.
// Demonstrates base.speak() chaining and multi-level override.
export class GuideDog extends Dog {
    private string owner;

    public new(string name, string owner) {
        base(name);
        this.owner = owner;
    }

    public override function string speak() {
        return base.speak() + " (guides " + this.owner + ")";
    }
}
