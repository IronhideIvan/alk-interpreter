import { log } from "console";

// ── const with an explicit type ─────────────────────────────────────────────

const int max = 100;
log("max=" + max);

// ── const var (inferred type) ───────────────────────────────────────────────

const var label = "fixed";
log("label=" + label);

// ── const array: binding and contents are both frozen ───────────────────────
//
// Neither the variable ('items') nor the array itself may be mutated.
// 'items = [...]'  — reassignment  → error (const binding)
// 'items.push(x)' — array mutation → error (frozen array)

const int[] items = [1, 2, 3];
log("items.length=" + items.length);
log("items[2]=" + items[2]);

log("done");
